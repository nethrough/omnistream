{
  "name": "wickstream",
  "version": "1.0.0",
  "description": "Stream anything. Open source by Wicky.",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend",
    "electron:dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\" \"wait-on http://localhost:5173 && electron .\"",
    "dist:mac": "npm run build && electron-builder --mac --universal",
    "dist:win": "npm run build && electron-builder --win",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "axios-retry": "^4.5.0",
    "cheerio": "^1.2.0",
    "connect-timeout": "^1.9.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "morgan": "^1.10.1",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "dev.wicky.wickstream",
    "productName": "Wickstream",
    "copyright": "Open source by Wicky",
    "files": [
      "electron/**/*",
      "backend/src/**/*",
      "!backend/node_modules",
      "!frontend"
    ],
    "extraResources": [
      { "from": "frontend/dist", "to": "frontend/dist" }
    ],
    "directories": {
      "output": "dist-electron"
    },
    "mac": {
      "category": "public.app-category.entertainment",
      "minimumSystemVersion": "10.15.0",
      "target": [
        { "target": "dmg", "arch": ["universal"] }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
